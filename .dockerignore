# Keep the build context small and deterministic. The wheel is built from pyproject + src +
# the license/readme files; nothing below is needed to `pip install .`.
.git
.github
.gitignore
.venv
venv
**/__pycache__
*.pyc
*.pyo
.pytest_cache
.mypy_cache
.ruff_cache
.coverage
htmlcov
dist
build
*.egg-info
tests
docs
uv.lock
Dockerfile
.dockerignore
