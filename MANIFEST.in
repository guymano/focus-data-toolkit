# Source distribution contents (the wheel is governed by [tool.setuptools.package-data]).
# LICENSE is included automatically via PEP 639 license-files; listed here for older tooling.
include LICENSE
include NOTICE
recursive-include LICENSES *.txt
include CHANGELOG.md
include SECURITY.md
include CONTRIBUTING.md
include pyproject.toml

# Ship the PEP 561 marker and the embedded FOCUS 1.4 model/reference JSON (incl. model_provenance.json).
recursive-include src/focus_data_toolkit py.typed *.json

# Ship the model extractor, the provenance schema + verifier, and the docs so the build and the
# embedded model are reproducible/verifiable from the sdist (the extractor is the source-of-record
# process for src/focus_data_toolkit/model/*.json; the verifier + schema gate its provenance).
include tools/extract_focus_1_4_model.py
recursive-include scripts *.py
recursive-include schema *.json
recursive-include docs *.md
recursive-include tests *.py *.csv *.json *.md

global-exclude *.py[cod]
global-exclude __pycache__
prune **/__pycache__
